{
  "name": "@powersync/react-custom-auth-todolist",
  "version": "0.2.3",
  "license": "CC0-1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "vite",
    "dev:local": "node scripts/local-dev.ts",
    "dev:convex": "convex dev",
    "build": "tsc -b && vite build",
    "build:github-pages": "pnpm build && cp dist/index.html dist/404.html",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "prepare:husky": "husky",
    "preview": "vite preview",
    "start": "pnpm build && pnpm preview",
    "prepare:isolated:test": "pnpm exec playwright install --with-deps",
    "test": "vitest run",
    "update:schema": "powersync generate schema --output-path=./src/library/powersync/AppSchema.ts --output=ts"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.93",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@journeyapps/wa-sqlite": "^1.5.0",
    "@mui/icons-material": "^5.15.15",
    "@mui/material": "^5.15.12",
    "@mui/x-data-grid": "^6.19.6",
    "@powersync/common": "^1.53.2",
    "@powersync/react": "^1.10.0",
    "@powersync/web": "^1.38.2",
    "convex": "^1.40.0",
    "formik": "^2.4.6",
    "js-logger": "^1.6.1",
    "jwt-decode": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.0.11",
    "@testing-library/react": "^16.3.0",
    "@vitest/browser": "^3.2.4",
    "lint-staged": "^15.2.2",
    "playwright": "^1.52.0",
    "powersync": "^0.9.6",
    "prettier": "^3.2.5",
    "prettier-plugin-embed": "^0.4.15",
    "prettier-plugin-sql": "^0.18.1",
    "typescript": "^5.4.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@journeyapps/wa-sqlite"
    ]
  }
}
